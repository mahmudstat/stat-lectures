plot(x, px,
type = "h",      # "h" for histogram-like vertical lines
xlab = "Value (x)",
ylab = 'Probability',
ylim = c(0, 0.5), # Ensure enough space above the highest point for labels
lwd = 2,         # Line width
col = "darkblue" # Line color (optional)
)
# Add the probability values as text labels above the lines
