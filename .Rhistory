# Create the line diagram for Series 1 with point labels
ggplot(df1, aes(x = x, y = y)) +
geom_line(color = "steelblue", size = 1) + # Line for Series 1
geom_point(color = "steelblue", size = 3) + # Points for Series 1
# Add text labels for the Y value next to each point
geom_text(aes(label = y),             # Label with the 'y' value
vjust = -1.5,               # Adjust vertical position (above the point)
hjust = 0.5,                # Adjust horizontal position (centered)
color = "black",            # Color of the label text
size = 3.5) +               # Size of the label text
# Customize the y-axis to show specific value labels
scale_y_continuous(
name = "Runs", # Label for the y-axis
breaks = seq(0, max(df1$y) + 2, by = 1), # Ensure breaks cover the range including label space
labels = seq(0, max(df1$y) + 2, by = 1) # Label every integer value
) +
# Customize the x-axis for Series 1
scale_x_continuous(
name = "Overs", # Label for the x-axis
breaks = df1$x, # Show breaks at all x-values
labels = df1$x # Label all x-values
) +
# Adjust plot limits to make space for labels
expand_limits(y = c(min(df1$y) - 2, max(df1$y) + 2)) + # Expand y-axis limits
# Add titles
labs(title = "Runs in Each Over by Bowler 2")
